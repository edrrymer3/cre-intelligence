generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 Int        @id @default(autoincrement())
  name               String
  ticker             String?
  cik                String     @unique
  source             String
  hq_city            String?
  hq_state           String?
  incorporated_state String?
  include_override   Boolean    @default(false)
  override_reason    String?
  active             Boolean    @default(true)
  added_by           String?
  added_date         DateTime   @default(now())
  notes              String?
  properties         Property[]
  alerts             Alert[]
  pipeline           Pipeline[]
  filings            Filing[]
  document_tenants    DocumentTenant[]
  portfolio_locations PortfolioLocation[]
  contacts            Contact[]
  outreach_emails     OutreachEmail[]
  research_reports    ResearchReport[]
  priority_score      PriorityScore?
  news                CompanyNews[]
  team_notes          TeamNote[]
  team_assignments    TeamAssignment[]
  deals               Deal[]
}

model REIT {
  id         Int        @id @default(autoincrement())
  name       String
  ticker     String?
  cik        String     @unique
  active     Boolean    @default(true)
  properties Property[]
  filings    Filing[]
}

model Filing {
  id             Int       @id @default(autoincrement())
  company_id     Int?
  reit_id        Int?
  filing_type    String
  filing_date    DateTime
  period         String?
  raw_text_url   String?
  processed      Boolean   @default(false)
  processed_date DateTime?
  company        Company?  @relation(fields: [company_id], references: [id])
  reit           REIT?     @relation(fields: [reit_id], references: [id])
}

model Property {
  id                    Int       @id @default(autoincrement())
  company_id            Int?
  reit_id               Int?
  tenant_name           String?
  property_type         String
  city                  String?
  state                 String?
  sqft                  Int?
  lease_expiration_year Int?
  lease_type            String?
  percent_of_building   Float?
  occupancy_trend       String?
  opportunity_score     Int?
  real_estate_strategy  String?
  trigger_events        String[]
  recommended_action    String?
  notes                 String?
  contacted             Boolean   @default(false)
  filing_date           DateTime?
  filing_url            String?
  company               Company?  @relation(fields: [company_id], references: [id])
  reit                  REIT?     @relation(fields: [reit_id], references: [id])
}

model Alert {
  id          Int      @id @default(autoincrement())
  company_id  Int
  alert_type  String
  summary     String
  filing_date DateTime
  filing_url  String?
  reviewed    Boolean  @default(false)
  company     Company  @relation(fields: [company_id], references: [id])
}

model Pipeline {
  id            Int      @id @default(autoincrement())
  company_id    Int
  contact_name  String?
  contact_title String?
  status        String
  notes         String?
  added_date    DateTime @default(now())
  last_updated  DateTime @updatedAt
  company       Company  @relation(fields: [company_id], references: [id])
}

model PortfolioClient {
  id            Int                    @id @default(autoincrement())
  name          String
  industry      String?
  primary_contact String?
  contact_email String?
  contact_phone String?
  notes         String?
  added_date    DateTime               @default(now())
  last_updated  DateTime               @updatedAt
  locations     PortfolioLocation[]
}

model PortfolioLocation {
  id                    Int              @id @default(autoincrement())
  client_id             Int
  company_id            Int?
  property_name         String?
  address               String?
  city                  String?
  state                 String?
  property_type         String?
  sqft                  Int?
  annual_rent           Float?
  lease_expiration_date DateTime?
  lease_type            String?
  landlord              String?
  notes                 String?
  client                PortfolioClient  @relation(fields: [client_id], references: [id])
  company               Company?         @relation(fields: [company_id], references: [id])
}

model Document {
  id             Int                @id @default(autoincrement())
  file_name      String
  file_url       String
  document_type  String
  uploaded_by    String
  uploaded_date  DateTime           @default(now())
  processed      Boolean            @default(false)
  processed_date DateTime?
  notes          String?
  properties     DocumentProperty[]
}

model DocumentProperty {
  id             Int              @id @default(autoincrement())
  document_id    Int
  property_name  String?
  address        String?
  city           String?
  state          String?
  property_type  String?
  total_sqft     Int?
  asking_price   Float?
  noi            Float?
  cap_rate       Float?
  occupancy_rate Float?
  year_built     Int?
  notes          String?
  tenants        DocumentTenant[]
  document       Document         @relation(fields: [document_id], references: [id])
}

model DocumentTenant {
  id                    Int              @id @default(autoincrement())
  document_property_id  Int
  matched_company_id    Int?
  tenant_name           String?
  sqft                  Int?
  lease_expiration_year Int?
  lease_expiration_month Int?
  rent_psf              Float?
  lease_type            String?
  options               String?
  notes                 String?
  document_property     DocumentProperty @relation(fields: [document_property_id], references: [id])
  matched_company       Company?         @relation(fields: [matched_company_id], references: [id])
}

model Contact {
  id           Int             @id @default(autoincrement())
  company_id   Int
  name         String?
  title        String?
  linkedin_url String?
  email        String?
  confidence   String?
  source       String?
  notes        String?
  added_date   DateTime        @default(now())
  last_updated DateTime        @updatedAt
  company      Company         @relation(fields: [company_id], references: [id])
  emails       OutreachEmail[]
  activities   ContactActivity[]
  team_notes   TeamNote[]
  team_assignments TeamAssignment[]
}

model OutreachEmail {
  id             Int       @id @default(autoincrement())
  company_id     Int
  contact_id     Int?
  subject        String?
  body           String
  channel        String    @default("email")
  generated_date DateTime  @default(now())
  sent           Boolean   @default(false)
  sent_date      DateTime?
  notes          String?
  company        Company   @relation(fields: [company_id], references: [id])
  contact        Contact?  @relation(fields: [contact_id], references: [id])
}

model ResearchReport {
  id                Int      @id @default(autoincrement())
  company_id        Int
  report_text       String
  opportunity_rating String
  generated_date    DateTime @default(now())
  company           Company  @relation(fields: [company_id], references: [id])
}

model CompanyNews {
  id              Int      @id @default(autoincrement())
  company_id      Int
  headline        String
  summary         String
  relevance_score Int
  source_url      String?
  published_date  DateTime?
  added_date      DateTime @default(now())
  reviewed        Boolean  @default(false)
  company         Company  @relation(fields: [company_id], references: [id])
}

model TeamNote {
  id           Int      @id @default(autoincrement())
  company_id   Int?
  contact_id   Int?
  client_id    Int?
  author       String
  note         String
  created_date DateTime @default(now())
  pinned       Boolean  @default(false)
  company      Company? @relation(fields: [company_id], references: [id])
  contact      Contact? @relation(fields: [contact_id], references: [id])
}

model TeamAssignment {
  id            Int      @id @default(autoincrement())
  company_id    Int?
  contact_id    Int?
  assigned_to   String
  assigned_by   String
  assigned_date DateTime @default(now())
  notes         String?
  company       Company? @relation(fields: [company_id], references: [id])
  contact       Contact? @relation(fields: [contact_id], references: [id])
}

model Deal {
  id                  Int             @id @default(autoincrement())
  company_id          Int?
  client_id           Int?
  deal_name           String
  status              String
  property_type       String?
  target_city         String?
  target_state        String?
  target_sf_min       Int?
  target_sf_max       Int?
  target_move_date    DateTime?
  estimated_value_sf  Float?
  estimated_commission Float?
  probability         Int?
  assigned_to         String?
  notes               String?
  created_date        DateTime        @default(now())
  last_updated        DateTime        @updatedAt
  company             Company?        @relation(fields: [company_id], references: [id])
  client              Client?         @relation(fields: [client_id], references: [id])
  milestones          DealMilestone[]
  spaces              DealSpace[]
  comparisons         PropertyComparison[]
}

model DealMilestone {
  id             Int      @id @default(autoincrement())
  deal_id        Int
  milestone      String
  due_date       DateTime?
  completed      Boolean  @default(false)
  completed_date DateTime?
  notes          String?
  deal           Deal     @relation(fields: [deal_id], references: [id])
}

model DealSpace {
  id             Int     @id @default(autoincrement())
  deal_id        Int
  building_name  String?
  address        String?
  city           String?
  state          String?
  floor          String?
  sqft           Int?
  asking_rate_psf Float?
  concessions    String?
  term_years     Int?
  status         String?
  notes          String?
  deal           Deal    @relation(fields: [deal_id], references: [id])
}

model PropertyComparison {
  id             Int      @id @default(autoincrement())
  deal_id        Int
  spaces         Json
  ai_analysis    String?
  generated_date DateTime @default(now())
  deal           Deal     @relation(fields: [deal_id], references: [id])
}

model PriorityScore {
  id                   Int      @id @default(autoincrement())
  company_id           Int      @unique
  score                Int
  lease_points         Int      @default(0)
  trigger_points       Int      @default(0)
  market_points        Int      @default(0)
  engagement_points    Int      @default(0)
  breakdown            String
  calculated_at        DateTime @default(now())
  company              Company  @relation(fields: [company_id], references: [id])
}

model ContactActivity {
  id              Int       @id @default(autoincrement())
  contact_id      Int
  activity_type   String
  summary         String
  activity_date   DateTime
  added_by        String
  follow_up_date  DateTime?
  follow_up_note  String?
  contact         Contact   @relation(fields: [contact_id], references: [id])
}

model MarketIntel {
  id              Int       @id @default(autoincrement())
  headline        String
  summary         String
  category        String
  relevance_score Int
  source_url      String?
  published_date  DateTime?
  added_date      DateTime  @default(now())
  reviewed        Boolean   @default(false)
}

model Client {
  id             Int             @id @default(autoincrement())
  name           String
  industry       String?
  hq_city        String?
  hq_state       String?
  employee_count Int?
  notes          String?
  added_by       String
  added_date     DateTime        @default(now())
  locations      ClientLocation[]
  contacts       ClientContact[]
  deals          Deal[]
}

model ClientLocation {
  id                Int       @id @default(autoincrement())
  client_id         Int
  property_name     String?
  address           String?
  city              String
  state             String
  property_type     String
  sqft              Int?
  lease_expiration  DateTime?
  landlord          String?
  annual_rent       Float?
  commission_earned Float?
  notes             String?
  client            Client    @relation(fields: [client_id], references: [id])
}

model ClientContact {
  id           Int     @id @default(autoincrement())
  client_id    Int
  name         String
  title        String?
  email        String?
  phone        String?
  linkedin_url String?
  primary      Boolean @default(false)
  notes        String?
  client       Client  @relation(fields: [client_id], references: [id])
}

model AppSettings {
  id                    Int     @id @default(autoincrement())
  weekly_digest_enabled Boolean @default(true)
  digest_email          String  @default("eddie@rymer.com")
  commission_rate_psf   Float   @default(2.00)
}

model User {
  id            Int    @id @default(autoincrement())
  email         String @unique
  password_hash String
  name          String
  role          String @default("member")
}
